generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  nrp               String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model evaluations {
  id            Int     @id @default(autoincrement())
  evaluator_nrp String?
  evaluated_nrp String?
  points        Int?
}

model group {
  id       Int     @id @default(autoincrement())
  nrp      String?
  group_id String?
}

model kriteria {
  idkriteria   Int     @id(map: "kriteria_pk") @default(autoincrement())
  namakriteria String? @db.VarChar
  bobot        Int?
}

model kuliah {
  idkuliah Int     @id(map: "kategori_pk") @default(autoincrement())
  matkul   String? @db.VarChar
  tahun    String? @db.VarChar
  nilai    nilai[]
}

model Nilai {
  idnilai       Int        @id(map: "nilai_pk") @default(autoincrement())
  grade         Decimal?   @db.Decimal
  kriteria      String?    @db.VarChar
  nrp           String?    @db.VarChar
  idkuliah      Int?
  judulkriteria String?    @db.VarChar
  bobot         Int?
  kuliah        kuliah?    @relation(fields: [idkuliah], references: [idkuliah], onDelete: NoAction, onUpdate: NoAction, map: "nilai_kuliah_fk")
  usernilai     usernilai? @relation(fields: [nrp], references: [nrp], onDelete: NoAction, onUpdate: NoAction, map: "nilai_usernilai_fk")

  @@map("nilai")
}

model User {
  nrp           String    @id 
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  usernilai     usernilai?
}

model UserNilai {
  nrp      String   @id @db.VarChar
  nama     String?  @db.VarChar
  password String?  @db.VarChar

  user     User     @relation(fields: [nrp], references: [nrp])

  nilai    nilai[]

  @@map("usernilai")

}

model submission {
  id         Int       @id @default(autoincrement())
  nrp        String?   @unique
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

model verificationtoken {
  id      Int       @id @default(autoincrement())
  token   String?   @unique
  expires DateTime? @db.Timestamp(6)

  @@unique([id, token], map: "constraint_1")
}
