generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  nrp               String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [nrp], references: [nrp], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  nrp          String
  expires      DateTime

  user User @relation(fields: [nrp], references: [nrp], onDelete: Cascade)
}

model Evaluations {
  id            Int     @id @default(autoincrement())
  evaluator_nrp String?
  evaluated_nrp String?
  points        Int?

  @@map("evaluations")
}

model Group {
  id       Int     @id @default(autoincrement())
  nrp      String?
  group_id String?

  @@map("group")
}

model Kriteria {
  idkriteria   Int     @id(map: "kriteria_pk") @default(autoincrement())
  namakriteria String? @db.VarChar
  bobot        Int?

  @@map("kriteria")
}

model Kuliah {
  idkuliah Int     @id(map: "kategori_pk") @default(autoincrement())
  matkul   String? @db.VarChar
  tahun    String? @db.VarChar
  nilai    Nilai[]

  @@map("kuliah")
}

model Nilai {
  idnilai       Int       @id(map: "nilai_pk") @default(autoincrement())
  grade         Decimal?  @db.Decimal
  kriteria      String?   @db.VarChar
  nrp           String    @db.VarChar
  idkuliah      Int?
  judulkriteria String?   @db.VarChar
  bobot         Int?
  kuliah        Kuliah?   @relation(fields: [idkuliah], references: [idkuliah], onDelete: NoAction, onUpdate: NoAction, map: "nilai_kuliah_fk")
  usernilai     UserNilai @relation(fields: [nrp], references: [nrp], onDelete: NoAction, onUpdate: NoAction, map: "nilai_usernilai_fk")

  @@map("nilai")
}

model User {
  nrp           String     @id
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  usernilai     UserNilai?
}

model UserNilai {
  nrp      String  @id @db.VarChar
  nama     String? @db.VarChar
  password String? @db.VarChar

  user User @relation(fields: [nrp], references: [nrp])

  nilai Nilai[]

  @@map("usernilai")
}

model Submission {
  id         Int       @id @default(autoincrement())
  nrp        String?   @unique
  created_at DateTime? @default(now()) @db.Timestamp(6)

  @@map("submission")
}

model VerificationToken {
  id      Int       @id @default(autoincrement())
  token   String?   @unique
  expires DateTime? @db.Timestamp(6)

  @@unique([id, token], map: "constraint_1")
  @@map("verificationtoken")
}
