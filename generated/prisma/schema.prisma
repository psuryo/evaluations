// prisma/schema.prisma
// Changes from previous version:
//   - UserNilai: added `email` field for NextAuth mapping
//   - Group: added `idkuliah` to support per-course group assignments
//   - Evaluations: added `idkuliah` + relations, compound unique to prevent duplicates
//   - Submission: changed from unique nrp to compound unique (nrp + idkuliah)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Evaluations {
  id            Int     @id @default(autoincrement())
  evaluator_nrp String?
  evaluated_nrp String?
  points        Int?
  idkuliah      Int?

  kuliah Kuliah? @relation(fields: [idkuliah], references: [idkuliah], onDelete: NoAction, onUpdate: NoAction)

  // Prevent a student from evaluating the same peer twice in the same course
  @@unique([evaluator_nrp, evaluated_nrp, idkuliah])
  @@map("evaluations")
}

model Group {
  id       Int     @id @default(autoincrement())
  nrp      String?
  group_id String?
  idkuliah Int?

  kuliah Kuliah? @relation(fields: [idkuliah], references: [idkuliah], onDelete: NoAction, onUpdate: NoAction)

  @@map("group")
}

model Kriteria {
  idkriteria   Int     @id(map: "kriteria_pk") @default(autoincrement())
  namakriteria String? @db.VarChar
  bobot        Int?

  @@map("kriteria")
}

model Kuliah {
  idkuliah    Int           @id(map: "kategori_pk") @default(autoincrement())
  matkul      String?       @db.VarChar
  tahun       String?       @db.VarChar
  nilai       Nilai[]
  evaluations Evaluations[]
  groups      Group[]
  submissions Submission[]

  @@map("kuliah")
}

model Nilai {
  idnilai       Int        @id(map: "nilai_pk") @default(autoincrement())
  grade         Decimal?   @db.Decimal
  kriteria      String?    @db.VarChar
  nrp           String?    @db.VarChar
  idkuliah      Int?
  judulkriteria String?    @db.VarChar
  bobot         Int?
  kuliah        Kuliah?    @relation(fields: [idkuliah], references: [idkuliah], onDelete: NoAction, onUpdate: NoAction, map: "nilai_kuliah_fk")
  usernilai     UserNilai? @relation(fields: [nrp], references: [nrp], onDelete: NoAction, onUpdate: NoAction, map: "nilai_usernilai_fk")

  @@map("nilai")
}

model UserNilai {
  nrp      String  @id(map: "usernilai_pk") @db.VarChar
  nama     String? @db.VarChar
  email    String? @unique @db.VarChar // ← new: maps NextAuth email to NRP
  password String? @db.VarChar
  nilai    Nilai[]

  @@map("usernilai")
}

model Submission {
  id         Int       @id @default(autoincrement())
  nrp        String?
  idkuliah   Int? // ← new: submission is now per course
  created_at DateTime? @default(now()) @db.Timestamp(6)

  kuliah Kuliah? @relation(fields: [idkuliah], references: [idkuliah], onDelete: NoAction, onUpdate: NoAction)

  // One submission per student per course
  @@unique([nrp, idkuliah])
  @@map("submission")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
